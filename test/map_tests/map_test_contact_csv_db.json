{
	"map_name": "test_contact",
	"map_version": "1.0",
	"engversion": "1.0",
	"author":      "YLA",
	"revisions" : [{
		"date": "02/12/2020",
		"author": "YLA",
		"title": "initial version"
	}],
	"eng_version": "1.0",
	"flux": "maptest",
	"sources": [{
		"medium":    "csv",
		"type":      "main",
		"srcname":   "people.csv",
		"name":      "people",
		"key":       "lastname",
		"params": {
			"file": "people.csv",
			"sep": "|",
			"del": "\""
		}
	}, {
		"medium": "csv",
		"type": "ref",
		"srcname":   "intit.csv",
		"name":      "intit",
		"key":       "code",
		"refkey":     "mrmrs",
		"params": {
			"file": "intit.csv",
			"sep": ";",
			"del": "\"",
			"cols" : [ "libelle" ]
		}
	}],
	"dest": {
		"medium": "db",
		"mode":   "line",
		"params": {
			"table": "contact",
			"schema": "public", 
			"dsn": "pgsql:host=localhost;dbname=maptest",
			"user": "ylanglais",
			"pass": "vcstHqqVWwEPg0Io"
		}
	},
    "map": [
        { "dest": "intitule", "map_value": "map_ref(intit, libelle)" },
        { "dest": "nom", "main": "lastname" },
        { "dest": "prenom", "main": "firstname" },
		{ "dest": "adresse", "main": "address" },
		{ "dest": "adresse2", "main": "address2" },
		{ "dest": "cp", "main": "zipcode" },
		{ "dest": "ville", "main": "city" },
		{ "dest": "date_entree", "map_value": "map_concat(map_src(in), '-', 01, '-', 01)" },
		{ "dest": "date_cre", "map_value": "map_if(map_less(map_src(created), '1900-01-01'), '1900-01-01', map_src(created))" },
		{ "dest": "date_maj", 
		  "map_value": "map_concat(map_substr(map_src(updated), 6, 4), '-', map_substr(map_src(updated), 0,2), '-', map_substr(map_src(updated), 3, 2))" }
    ]
}
