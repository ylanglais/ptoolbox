	"flux": "grf.contact.test",
	"sources": [{
		"medium":    "csv",
		"type":      "main",
		"srcname":   "grf.contact.5.csv",
		"name":      "contact",
		"key":       "codecontact",
		"params": {
			"file": "grf.contact.5.csv",
			"sep": "|",
			"del": "\""
		}
	}],
	"dest":{
		"medium": "db",
		"type": "main",
		"mode":   "line",
		"params": {
			"schema": "rcu", 
			"dsn": "pgsql:host=localhost;dbname=rcu1",
			"user": "ylanglais",
			"pass": "vcstHqqVWwEPg0Io"
        }
	},
        "fragments" : [{
			"table": "person",
			"type": "main",
			"id": { "field": "id", "type": "uuid" },
			"ref": "codecontact"
		}, {
			"table": "email",
			"type": "ref",
			"id": { "field": "id", "type": "uuid" },
			"ref": "email"
		}, {
			"table": "phone",
			"type": "ref",
			"id": { "field": "id", "type": "uuid" },
			"ref": "phone"
		}, {
			"table": "lnk_channel", 
			"type":  "link",
			"vlink": {
				"from_table": 	"entity",  
				"from_id":      "entity_id",
				"to_id": 		"channel_id",
				"to_extra_data" : "channel"
				
			}
       }],
	"map": [
		{ "dest": "id",  	      "map_value": 	"map_genuuid()" },
		{ "dest": "last_name",    "main": 		"nomf" 			},
		{ "dest": "first_name",   "main": 		"prenom" 		},
		{ "dest": "title",		  "main":		"civilite" 		},
		{ "dest": "map_vlink(lnk_channel, person, email, email,      RW)" },
		{ "dest": "map_vlink(lnk_channel, person, phone, telephone1, RW)" },
		{ "dest": "map_vlink(lnk_channel, person, phone, telephone2, RW)" },
		{ "dest": "map_vlink(lnk_channel, person, phone, telephone3, RW)" }
	]
}
