{
	"map_name": "Multi_dest",
	"map_version": "1.0",
	"engversion": "1.0",
	"author":      "RMK",
	"revisions" : [{
		"date": "19/03/2021",
		"author": "RMK",
		"title": "initial version"
	}],
	"eng_version": "1.0",
	"flux": "maptest",
	"sources": [{
		"medium":    "csv",
		"type":      "main",
		"srcname":   "users_canal.csv",
		"name":      "user",
		"key":       "login",
		"params": {
			"file": "users_canal.csv",
			"sep": ";",
			"del": "\""
		}
	}],
	"dest":{
		"medium": "db",
                "type": "main",
		"mode":   "line",
		"params": {
			"schema": "rcu", 
			"dsn": "pgsql:host=localhost;dbname=rcu1",
			"user": "ramsadak",
			"pass": "azerty"
                    }
        },
        "fragments" : [{
                        "table": "users",
                        "type": "main",
                        "id": { "field": "id", "type": "uuid" }
                       }, {
                        "table": "email",
                        "type":  "ref",
                        "id": { "field": "id", "type": "uuid" },
                        "ref": "mail"
                       }, {	
                        "table": "phone",
                        "type":  "ref",
                        "id": { "field": "id", "type": "uuid" },
                        "ref": "numero"
                       }, {
                        "table": "users_canal",
                        "type":  "link",
                        "vlink": {
                                "from_table": 	"users",  
                                "from_id":      "user_id",
                                "to_id": 		"canal_id",
                                "to_extra_data" : "canal"
                            }
                       }
        ],
        "map": [
                { "dest": "id",    	"map_value": 	"map_genuuid()" },
                { "dest": "login", 	"main": 		"login" },
                { "dest": "map_to_ref(phone, type, typetel)" },
                { "dest": "map_vlink(users_canal, login, email, email, RW)" },
                { "dest": "map_vlink(users_canal, login, email, email2, RW)" },               
                { "dest": "map_vlink(users_canal, login, phone, tel, RW)" }
        ]
}
