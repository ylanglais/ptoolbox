{
	"map_name": "Multi_dest",
	"map_version": "1.0",
	"engversion": "1.0",
	"author":      "RMK",
	"revisions" : [{
		"date": "19/03/2021",
		"author": "RMK",
		"title": "initial version"
	}],
	"eng_version": "1.0",
	"flux": "maptest",
	"sources": [{
		"medium":    "csv",
		"type":      "main",
		"srcname":   "contact.csv",
		"name":      "contact",
		"key":       "nom",
		"params": {
			"file": "contact.csv",
			"sep": ";",
			"del": "\""
		}
	}, {
		"medium": "csv",
		"type": "ref",
		"srcname":   "civilite.csv",
		"name":      "civilite",
		"key":       "id",
		"refkey":     "initule",
		"params": {
			"file": "civilite.csv",
			"sep": ";",
			"del": "\"",
			"cols" : [ "libelle" ]
		}
	}],
	"dest":{
		"medium": "db",
                "type": "main",
		"mode":   "line",
		"params": {
			"schema": "public", 
			"dsn": "pgsql:host=localhost;dbname=rcu1",
			"user": "ramsadak",
			"pass": "azerty"
                    }
        },
        "fragments" : [{
                        "table": "contacts",
                        "type" : "main"
                       },
                       {
                        "table": "civilites",
                        "type" : "ref",
                        "id": { "field": "id", "type": "seq"},
                        "ref": "libelle"                        
                        }
        ],
    "map": [
            { "dest": "id" , "map_value": "map_genuuid()" },
            { "dest": "cid", "map_value": "map_dst(civilites, initule,rw)" },
            { "dest": "prenom", "main": "prenom" },
            { "dest": "nom", "main": "nom" }
        ]

}
