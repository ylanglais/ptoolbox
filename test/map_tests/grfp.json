		{ "dest": "rcu.phone.type",        "map_value": "map_if(map_or(map_equal(map_substr(map_src(telephone1), 1, 1), 6), map_equal(map_substr(map_src(telephone1), 1, 1), 7)), portable, fixe)" },

		{ "dest": "rcu.phone.phone",       "main": "telephone2" },
		{ "dest": "rcu.lnk_channel",       "link": [ "rcu.person", "rcu.phone"]	},
		{ "dest": "rcu.origin",            "link": [ "rcu.phone"] },
		{ "dest": "rcu.origin.origin", 	   "map_value": "46e535c8-960a-46c2-9a31-12e36e2a1bb7" },
		{ "dest": "rcu.phone.type",        "map_value": "map_if(map_or(map_equal(map_substr(map_src(telephone2), 1, 1), 6), map_equal(map_substr(map_src(telephone2), 1, 1), 7)), portable, fixe)" },

		{ "dest": "rcu.phone.phone",       "main": "telephone3" },
		{ "dest": "rcu.lnk_channel",       "link": [ "rcu.person", "rcu.phone"]	},
		{ "dest": "rcu.origin",            "link": [ "rcu.phone"] },
		{ "dest": "rcu.origin.origin", 	   "map_value": "46e535c8-960a-46c2-9a31-12e36e2a1bb7" },
		{ "dest": "rcu.phone.type",        "map_value": "map_if(map_or(map_equal(map_substr(map_src(telephone3), 1, 1), 6), map_equal(map_substr(map_src(telephone3), 1, 1), 7)), portable, fixe)" },

